name: 'spice'
description: ''
publish_to: none
version: 1.0.0+1
environment:
  sdk: '>=3.1.5 <4.0.0'
dependencies:
  flutter:
    sdk: flutter
  flutter_web_plugins:
    sdk: flutter
  cupertino_icons: ^1.0.8
  flet: 0.85.3
  serious_python: 1.0.1
  package_info_plus: ^9.0.0
  path_provider: ^2.1.4
  path: ^1.9.0
  window_manager: ^0.5.1
dependency_overrides:
  flet: 0.85.3
  device_info_plus: 12.3.0
  connectivity_plus: 7.0.0
dev_dependencies:
  flutter_launcher_icons: ^0.14.1
  flutter_native_splash: ^2.4.1
  flutter_lints: ^2.0.0
flutter:
  uses-material-design: true
  assets:
  - app/app.zip
  - app/app.zip.hash
flutter_launcher_icons:
  image_path: images/icon.png
  android: true
  image_path_android: images/icon.png
  adaptive_icon_background: '#ffffff'
  adaptive_icon_foreground: images/icon.png
  ios: true
  image_path_ios: images/icon.png
  remove_alpha_ios: true
  web:
    generate: true
    image_path: images/icon.png
  windows:
    generate: true
    image_path: images/icon.png
    icon_size: 256
  macos:
    generate: true
    image_path: images/icon.png
flutter_native_splash:
  color: '#ffffff'
  image: images/icon.png
  color_dark: '#222222'
  image_dark: images/icon.png
  android_12:
    image: images/icon.png
    image_dark: images/icon.png
  android: true
  ios: true
  web: true
  image_android: images/icon.png
  image_dark_android: images/icon.png
  image_ios: images/icon.png
  image_dark_ios: images/icon.png
  image_web: images/icon.png
  image_dark_web: images/icon.png
